{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevOps Genie Agent",
  "description": "Values for dg-platform-agent Helm chart",
  "type": "object",
  "properties": {
    "agentId": {
      "type": "string",
      "description": "DevOps Genie agent identifier (provided by DG platform)"
    },
    "apiKey": {
      "type": "string",
      "description": "DevOps Genie API key (provided by DG platform)"
    },
    "imageCredentials": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "GitHub PAT with read:packages scope for pulling private images"
        },
        "username": {
          "type": "string",
          "default": "devopsgenie-ai"
        },
        "existingSecret": {
          "type": "string",
          "description": "Name of a pre-created kubernetes.io/dockerconfigjson Secret"
        }
      }
    },
    "maxAgents": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 10,
      "description": "Maximum number of concurrent agent pods"
    },
    "server": {
      "type": "object",
      "properties": {
        "wsUrl": {
          "type": "string",
          "pattern": "^wss?://"
        },
        "authUrl": {
          "type": "string",
          "pattern": "^https?://"
        }
      }
    },
    "credentials": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of a pre-created Secret containing DG_AGENT_ID and DG_API_KEY"
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "refreshInterval": {
              "type": "string",
              "default": "1h"
            },
            "secretStoreRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                }
              }
            },
            "data": {
              "type": "array"
            },
            "dataFrom": {
              "type": "array"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "not": {
          "anyOf": [
            {
              "required": ["credentials"],
              "properties": {
                "credentials": {
                  "required": ["existingSecret"],
                  "properties": {
                    "existingSecret": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            {
              "required": ["credentials"],
              "properties": {
                "credentials": {
                  "required": ["externalSecret"],
                  "properties": {
                    "externalSecret": {
                      "required": ["enabled"],
                      "properties": {
                        "enabled": { "const": true }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "then": {
        "required": ["agentId", "apiKey"],
        "properties": {
          "agentId": { "minLength": 1 },
          "apiKey": { "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "required": ["credentials"],
        "properties": {
          "credentials": {
            "required": ["externalSecret"],
            "properties": {
              "externalSecret": {
                "required": ["enabled"],
                "properties": {
                  "enabled": { "const": true }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "credentials": {
            "properties": {
              "externalSecret": {
                "required": ["secretStoreRef"],
                "properties": {
                  "secretStoreRef": {
                    "required": ["name", "kind"],
                    "properties": {
                      "name": { "minLength": 1 },
                      "kind": { "minLength": 1 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
