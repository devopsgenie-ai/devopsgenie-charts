{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevOps Genie Agent",
  "description": "Values for dg-platform-agent Helm chart",
  "type": "object",
  "properties": {
    "apiKey": {
      "type": "string",
      "description": "DevOps Genie API key (provided by DG platform)"
    },
    "imageCredentials": {
      "type": "object",
      "properties": {
        "registry": {
          "type": "string",
          "default": "registry.devopsgenie.ai"
        },
        "token": {
          "type": "string",
          "description": "Private registry token for pulling DevOps Genie agent images"
        },
        "username": {
          "type": "string",
          "default": ""
        },
        "existingSecret": {
          "type": "string",
          "description": "Name of a pre-created kubernetes.io/dockerconfigjson Secret"
        }
      }
    },
    "maxAgents": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 10,
      "description": "Maximum number of concurrent agent pods"
    },
    "server": {
      "type": "object",
      "properties": {
        "wsUrl": {
          "type": "string",
          "pattern": "^wss?://"
        },
        "authUrl": {
          "type": "string",
          "pattern": "^https?://"
        }
      }
    },
    "controller": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1,
          "default": 1,
          "description": "Number of controller replicas. Currently capped at 1 — leader election is not yet implemented."
        },
        "env": {
          "type": "object",
          "description": "Additional non-sensitive env vars for the controller pod. AGENT_LLM_TIMEOUT_SECONDS and AGENT_LLM_MAX_RETRIES are reserved; use agentPod.llm instead.",
          "propertyNames": {
            "not": {
              "enum": [
                "AGENT_LLM_TIMEOUT_SECONDS",
                "AGENT_LLM_MAX_RETRIES"
              ]
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        }
      }
    },
    "agentPod": {
      "type": "object",
      "properties": {
        "llm": {
          "type": "object",
          "properties": {
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1,
              "default": 300,
              "description": "Per-request LiteLLM client timeout in seconds"
            },
            "maxRetries": {
              "type": "integer",
              "minimum": 0,
              "default": 2,
              "description": "LiteLLM client retry count"
            }
          }
        },
        "env": {
          "type": "object",
          "description": "Additional non-sensitive env vars for agent pods. AGENT_LLM_TIMEOUT_SECONDS and AGENT_LLM_MAX_RETRIES are reserved; use agentPod.llm instead.",
          "propertyNames": {
            "not": {
              "enum": [
                "AGENT_LLM_TIMEOUT_SECONDS",
                "AGENT_LLM_MAX_RETRIES"
              ]
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "workspaceSize": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|k|M|G|T|P|E)?$",
          "description": "Workspace volume size (Kubernetes quantity, e.g. \"10Gi\", \"500Mi\")."
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "name": {
              "type": "string"
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "vcs": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["github", "gitlab", "bitbucket"],
          "description": "VCS provider for the agent's git operations."
        },
        "token": { "type": "string" },
        "infrastructureRepoUrl": { "type": "string" },
        "infrastructureRepoPath": { "type": "string" },
        "deploymentRepoUrl": { "type": "string" },
        "deploymentRepoPath": { "type": "string" },
        "githubApp": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "installationId": { "type": "string" },
            "privateKey": { "type": "string" }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "sessionIdleTtlSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "allowedPrivateCidrs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
              }
            },
            "publicEgressPorts": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            },
            "extraEgress": {
              "type": "array",
              "description": "Additional NetworkPolicy egress rules. These are passed through verbatim and can widen egress if misconfigured.",
              "items": {
                "type": "object",
                "required": ["to", "ports"],
                "properties": {
                  "to": {
                    "type": "array"
                  },
                  "ports": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "credentials": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of a pre-created Secret containing DG_API_KEY"
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "refreshInterval": {
              "type": "string",
              "default": "1h"
            },
            "secretStoreRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                }
              }
            },
            "data": {
              "type": "array"
            },
            "dataFrom": {
              "type": "array"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "not": {
          "anyOf": [
            {
              "required": ["credentials"],
              "properties": {
                "credentials": {
                  "required": ["existingSecret"],
                  "properties": {
                    "existingSecret": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            {
              "required": ["credentials"],
              "properties": {
                "credentials": {
                  "required": ["externalSecret"],
                  "properties": {
                    "externalSecret": {
                      "required": ["enabled"],
                      "properties": {
                        "enabled": { "const": true }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "then": {
        "required": ["apiKey"],
        "properties": {
          "apiKey": { "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "required": ["credentials"],
        "properties": {
          "credentials": {
            "required": ["externalSecret"],
            "properties": {
              "externalSecret": {
                "required": ["enabled"],
                "properties": {
                  "enabled": { "const": true }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "credentials": {
            "properties": {
              "externalSecret": {
                "required": ["secretStoreRef"],
                "properties": {
                  "secretStoreRef": {
                    "required": ["name", "kind"],
                    "properties": {
                      "name": { "minLength": 1 },
                      "kind": { "minLength": 1 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "not": {
          "anyOf": [
            {
              "required": ["imageCredentials"],
              "properties": {
                "imageCredentials": {
                  "required": ["token"],
                  "properties": {
                    "token": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            {
              "required": ["imageCredentials"],
              "properties": {
                "imageCredentials": {
                  "required": ["existingSecret"],
                  "properties": {
                    "existingSecret": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          ]
        }
      },
      "then": {
        "description": "Either imageCredentials.token or imageCredentials.existingSecret must be set.",
        "required": ["imageCredentials"],
        "properties": {
          "imageCredentials": {
            "anyOf": [
              {
                "required": ["token"],
                "properties": {
                  "token": { "minLength": 1 }
                }
              },
              {
                "required": ["existingSecret"],
                "properties": {
                  "existingSecret": { "minLength": 1 }
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": ["imageCredentials"],
        "properties": {
          "imageCredentials": {
            "required": ["token"],
            "properties": {
              "token": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "then": {
        "properties": {
          "imageCredentials": {
            "required": ["username"],
            "properties": {
              "username": { "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "vcs": {
            "anyOf": [
              {
                "required": ["infrastructureRepoUrl"],
                "properties": { "infrastructureRepoUrl": { "minLength": 1 } }
              },
              {
                "required": ["deploymentRepoUrl"],
                "properties": { "deploymentRepoUrl": { "minLength": 1 } }
              }
            ]
          }
        }
      },
      "then": {
        "description": "When vcs.infrastructureRepoUrl or vcs.deploymentRepoUrl is set, either vcs.token or vcs.githubApp.id must be provided.",
        "properties": {
          "vcs": {
            "anyOf": [
              {
                "required": ["token"],
                "properties": {
                  "token": { "minLength": 1 }
                }
              },
              {
                "properties": {
                  "githubApp": {
                    "required": ["id", "installationId", "privateKey"],
                    "properties": {
                      "id": { "minLength": 1 },
                      "installationId": { "minLength": 1 },
                      "privateKey": { "minLength": 1 }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "vcs": {
            "properties": {
              "githubApp": {
                "anyOf": [
                  {
                    "required": ["id"],
                    "properties": { "id": { "minLength": 1 } }
                  },
                  {
                    "required": ["installationId"],
                    "properties": { "installationId": { "minLength": 1 } }
                  },
                  {
                    "required": ["privateKey"],
                    "properties": { "privateKey": { "minLength": 1 } }
                  }
                ]
              }
            }
          }
        }
      },
      "then": {
        "description": "GitHub App auth requires vcs.githubApp.id, vcs.githubApp.installationId, and vcs.githubApp.privateKey together.",
        "properties": {
          "vcs": {
            "properties": {
              "githubApp": {
                "required": ["id", "installationId", "privateKey"],
                "properties": {
                  "id": { "minLength": 1 },
                  "installationId": { "minLength": 1 },
                  "privateKey": { "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  ]
}
